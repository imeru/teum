# 보안 응답 헤더 — Netlify / Cloudflare Pages 형식.
# ⚠️ GitHub Pages에서는 무시됩니다(커스텀 헤더 미지원, 이 파일은 정적으로 서빙만 됨).
#    실제로 적용하려면 이 _headers를 지원하는 호스트(Netlify·Cloudflare Pages)로 배포하세요.
/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://btmyvomigijtikajaazv.supabase.co wss://btmyvomigijtikajaazv.supabase.co; font-src 'self'; manifest-src 'self'; worker-src 'self'; base-uri 'self'; form-action 'self'; object-src 'none'; frame-ancestors 'none'
